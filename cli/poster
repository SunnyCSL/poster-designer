def _fmt_state(state: dict, json_out: bool) -> str:
    if json_out:
        return ""
    meta = state.get("meta", {})
    w, h = meta.get("width_mm", "?"), meta.get("height_mm", "?")
    elements = state.get("elements", [])
    return f"State: {meta.get('template', '?')} ({w}×{h}mm), {len(elements)} element(s)"


def _fmt_element(res: dict, json_out: bool) -> str:
    if json_out:
        return ""
    # API returns [element, status_code] for element creation
    if isinstance(res, list):
        el = res[0] if len(res) > 0 else {}
    else:
        el = res.get("element", res)
    el_type = el.get("type", "?")
    el_id = el.get("id", "?")
    content = el.get("content", el.get("src", el.get("shapeType", "")))
    pos = el.get("position", {})
    x, y = pos.get("x", 0), pos.get("y", 0)
    return f"✅ Element {el_id} added: '{content}' ({el_type}) at ({x}, {y})"


def main():
    args = parser.parse_args()
    cli = PosterCLI(server_url=args.server)

    try:
        cmd = args.command

        # ── State ──────────────────────────────────────────────────────────────
        if cmd == "state":
            state = cli.get_state()
            if args.json:
                out("", json_output=True, data=state)
            else:
                out(_fmt_state(state, False))
                for el in state.get("elements", []):
                    pos = el.get("position", {})
                    out(f"  • {el.get('id')} [{el.get('type')}] '{el.get('content', el.get('src', ''))}' "
                        f"@ ({pos.get('x',0)}, {pos.get('y',0)})")

        # ── New ───────────────────────────────────────────────────────────────
        elif cmd == "new":
            res = cli.new_design(args.template)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ New design created: {args.template}")

        # ── Add-text ──────────────────────────────────────────────────────────
        elif cmd == "add-text":
            font_weight = args.font_weight
            if args.bold:
                font_weight = "bold"
            res = cli.add_text(
                args.content, args.x, args.y,
                **{
                    "width": args.width,
                    "height": args.height,
                    "font-size": args.font_size,
                    "font-weight": font_weight,
                    "font-family": args.font_family,
                    "color": args.color,
                    "text-align": args.text_align,
                    "line-height": args.line_height,
                    "letter-spacing": args.letter_spacing,
                    "rotation": args.rotation,
                    "layer": args.layer,
                    "locked": args.locked,
                    "visible": args.visible,
                },
            )
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(_fmt_element(res, False))

        # ── Add-image ──────────────────────────────────────────────────────────
        elif cmd == "add-image":
            res = cli.add_image(
                args.src, args.x, args.y,
                **{
                    "width": args.width,
                    "height": args.height,
                    "rotation": args.rotation,
                    "layer": args.layer,
                    "locked": args.locked,
                    "visible": args.visible,
                },
            )
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(_fmt_element(res, False))

        # ── Add-shape ──────────────────────────────────────────────────────────
        elif cmd == "add-shape":
            res = cli.add_shape(
                args.shape_type, args.x, args.y, args.width, args.height,
                **{
                    "fill": args.fill,
                    "stroke": args.stroke,
                    "stroke-width": args.stroke_width,
                    "rotation": args.rotation,
                    "layer": args.layer,
                    "locked": args.locked,
                    "visible": args.visible,
                },
            )
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(_fmt_element(res, False))

        # ── Update ─────────────────────────────────────────────────────────────
        elif cmd == "update":
            # Build kwargs from provided args
            kwargs = {}
            if args.content is not None:
                kwargs["content"] = args.content
            if args.x is not None:
                kwargs["position.x"] = args.x
            if args.y is not None:
                kwargs["position.y"] = args.y
            if args.width is not None:
                kwargs["width"] = args.width
            if args.height is not None:
                kwargs["height"] = args.height
            if args.font_size is not None:
                kwargs["style.fontSize"] = args.font_size
            if args.font_weight is not None:
                kwargs["style.fontWeight"] = args.font_weight
            if args.font_family is not None:
                kwargs["style.fontFamily"] = args.font_family
            if args.color is not None:
                kwargs["style.color"] = args.color
            if args.text_align is not None:
                kwargs["style.textAlign"] = args.text_align
            if args.line_height is not None:
                kwargs["style.lineHeight"] = args.line_height
            if args.letter_spacing is not None:
                kwargs["style.letterSpacing"] = args.letter_spacing
            if args.rotation is not None:
                kwargs["rotation"] = args.rotation
            if args.layer is not None:
                kwargs["layer"] = args.layer
            if args.locked is not None:
                kwargs["locked"] = args.locked
            if args.visible is not None:
                kwargs["visible"] = args.visible

            res = cli.update_element(args.element_id, **kwargs)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Element {args.element_id} updated.")

        # ── Remove ────────────────────────────────────────────────────────────
        elif cmd == "remove":
            res = cli.remove_element(args.element_id)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Element {args.element_id} removed.")

        # ── Reorder ───────────────────────────────────────────────────────────
        elif cmd == "reorder":
            res = cli.reorder_layers(args.element_ids)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Layers reordered: {' → '.join(args.element_ids)}")

        # ── Set-bg ─────────────────────────────────────────────────────────────
        elif cmd == "set-bg":
            kwargs = {}
            if args.color:
                kwargs["color"] = args.color
            if args.type:
                kwargs["type"] = args.type
            if args.gradient_angle:
                kwargs["gradientAngle"] = args.gradient_angle
            if args.gradient_start:
                kwargs["gradientStart"] = args.gradient_start
            if args.gradient_end:
                kwargs["gradientEnd"] = args.gradient_end
            if args.image_url:
                kwargs["imageUrl"] = args.image_url

            res = cli.set_background(**kwargs)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Background set.")

        # ── Undo ───────────────────────────────────────────────────────────────
        elif cmd == "undo":
            res = cli.undo()
            if args.json:
                out("", json_output=True, data=res)
            else:
                template = res.get("meta", {}).get("template", "?")
                out(f"✅ Undo complete — restored to {template}")

        # ── History ────────────────────────────────────────────────────────────
        elif cmd == "history":
            res = cli.get_history(args.limit)
            if args.json:
                out("", json_output=True, data=res)
            else:
                entries = res if isinstance(res, list) else res.get("history", [])
                if not entries:
                    out("No history entries.")
                for entry in entries:
                    out(f"  [{entry.get('timestamp', '')}] {entry.get('action', '?')}")

        # ── Templates ─────────────────────────────────────────────────────────
        elif cmd == "templates":
            res = cli.list_templates()
            if args.json:
                out("", json_output=True, data=res)
            else:
                if isinstance(res, dict):
                    for name, info in res.items():
                        desc = f"{info.get('width_mm', '?')}×{info.get('height_mm', '?')}mm"
                        out(f"  • {name} — {desc}")
                elif isinstance(res, list):
                    for t in res:
                        out(f"  • {t.get('name')} — {t.get('description', '')}")

        # ── Compose ─────────────────────────────────────────────────────────────
        elif cmd == "compose":
            res = cli.compose()
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Design composed.")

        # ── Export ──────────────────────────────────────────────────────────────
        elif cmd == "export":
            res = cli.export(args.format)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Exported as {args.format}: {res.get('path', '')}")

        # ── Batch ───────────────────────────────────────────────────────────────
        elif cmd == "batch":
            res = cli.batch(args.file)
            if args.json:
                out("", json_output=True, data=res)
            else:
                count = res.get("applied", 0)
                out(f"✅ Applied {count} batch operation(s).")

        # ── Upload ─────────────────────────────────────────────────────────────
        elif cmd == "upload":
            res = cli.upload(args.filepath)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ Uploaded: {res.get('url', args.filepath)}")

        # ── Load ───────────────────────────────────────────────────────────────
        elif cmd == "load":
            res = cli.load(args.filepath)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ State loaded from {args.filepath}")

        # ── Save ───────────────────────────────────────────────────────────────
        elif cmd == "save":
            res = cli.save(args.filepath)
            if args.json:
                out("", json_output=True, data=res)
            else:
                out(f"✅ State saved to {args.filepath}")

        # ── From-vision ───────────────────────────────────────────────────────────
        elif cmd == "from-vision":
            import scripts.vision_to_poster as v2p
            import argparse as ap

            # Mirror the vision-to-poster.py CLI interface
            vision_args = [args.image]
            if args.analyze:
                vision_args.append("--analyze")
            else:
                vision_args.append("--auto")
            vision_args.extend(["--template", args.template])
            vision_args.extend(["--server", args.server])

            old_argv = sys.argv
            sys.argv = ["vision-to-poster.py"] + vision_args
            try:
                v2p.main()
            finally:
                sys.argv = old_argv

        # ── From-text ──────────────────────────────────────────────────────────────
        elif cmd == "from-text":
            import subprocess as sp_run
            scripts_dir = PROJECT_DIR / "scripts"
            cmd = [sys.executable, str(scripts_dir / "nl-to-poster.py")]
            if args.description:
                cmd.append(args.description)
            if args.template:
                cmd.extend(["--template", args.template])
            if args.image:
                cmd.extend(["--image", args.image])
            if args.dry_run:
                cmd.append("--dry-run")
            cmd.extend(["--server", args.server])
            sp_run.run(cmd)

        # ── From-speech ───────────────────────────────────────────────────────────
        elif cmd == "from-speech":
            import subprocess as sp_run
            scripts_dir = PROJECT_DIR / "scripts"
            cmd = [sys.executable, str(scripts_dir / "speech-to-poster.py")]
            if args.audio:
                cmd.append(args.audio)
            if args.template:
                cmd.extend(["--template", args.template])
            if getattr(args, 'record', False):
                cmd.append("--record")
            cmd.extend(["--server", args.server])
            sp_run.run(cmd)

        else:
            fatal(f"Unknown command: {cmd}")

    except PosterAPIError as e:
        fatal(f"Server error: {e.message}")
    except FileNotFoundError as e:
        fatal(f"File not found: {e}")
    except json.JSONDecodeError as e:
        fatal(f"Invalid JSON: {e}")
    except Exception as e:
        fatal(f"Unexpected error: {e}")


if __name__ == "__main__":
    main()
