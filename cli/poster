# ── Output helpers ──────────────────────────────────────────────────────────

def out(msg: str, *, json_output: bool = False, data: dict = None):
    if json_output and data is not None:
        print(json.dumps(data, indent=2, ensure_ascii=False))
    else:
        print(msg)


def fatal(msg: str):
    print(f"❌  {msg}", file=sys.stderr)
    sys.exit(1)


